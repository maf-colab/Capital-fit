<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Capital-Fit Navigator</title>
    <!-- Tailwind CSS for modern styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js for Radar and Area charts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            background: #4f46e5;
            cursor: pointer;
            border-radius: 50%;
        }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 font-sans">

    <div class="min-h-screen flex flex-col">
        <!-- Header -->
        <header class="bg-white border-b border-slate-200 px-8 py-4 flex justify-between items-center sticky top-0 z-50">
            <div class="flex items-center gap-3">
                <div class="bg-indigo-600 p-2 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="text-white w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-tight">Capital-Fit Navigator</h1>
                    <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Tourism Finance Support</p>
                </div>
            </div>
            <button onclick="window.print()" class="px-4 py-2 text-sm font-semibold border border-slate-200 rounded-md hover:bg-slate-50 transition-colors flex items-center gap-2">
                Download PDF
            </button>
        </header>

        <div class="flex flex-1 overflow-hidden">
            <!-- Sidebar: Inputs -->
            <aside class="w-80 bg-white border-r border-slate-200 overflow-y-auto p-6 scrollbar-hide">
                <h2 class="text-xs font-black text-slate-400 mb-6 uppercase tracking-widest border-b pb-2">Venture Physics</h2>
                
                <div class="space-y-6">
                    <div>
                        <h3 class="text-xs font-bold text-slate-800 mb-4 uppercase italic">Revenue & Ops</h3>
                        <div class="space-y-4" id="inputs-ops"></div>
                    </div>
                    <div>
                        <h3 class="text-xs font-bold text-slate-800 mb-4 uppercase italic">Growth & Upside</h3>
                        <div class="space-y-4" id="inputs-growth"></div>
                    </div>
                    <div>
                        <h3 class="text-xs font-bold text-slate-800 mb-4 uppercase italic">Impact & Context</h3>
                        <div class="space-y-4" id="inputs-impact"></div>
                    </div>
                </div>
            </aside>

            <!-- Main Content: Dashboard -->
            <main class="flex-1 overflow-y-auto p-8">
                <!-- Score Cards -->
                <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8" id="score-cards">
                    <!-- Dynamic Content -->
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Charts -->
                    <div class="lg:col-span-2 space-y-8">
                        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                            <h3 class="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                                <span class="w-2 h-2 bg-indigo-500 rounded-full"></span> Fitness Radar
                            </h3>
                            <div class="h-[350px]">
                                <canvas id="radarChart"></canvas>
                            </div>
                        </div>

                        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                            <h3 class="text-sm font-bold text-slate-800 mb-4">Cash Runway Projection</h3>
                            <div class="h-[250px]">
                                <canvas id="areaChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Recommendations Sidebar -->
                    <div class="space-y-6">
                        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm" id="rec-box">
                            <h3 class="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                                Suggestions
                            </h3>
                            <ul class="space-y-3" id="suggestion-list"></ul>
                        </div>

                        <div class="bg-indigo-900 p-6 rounded-2xl shadow-lg text-white">
                            <h3 class="text-sm font-bold mb-4 flex items-center gap-2">Readiness Checklist</h3>
                            <div class="space-y-3" id="checklist-items"></div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        // --- DATA & CONFIG ---
        const state = {
            revPredictability: 4,
            repaymentCapacity: 3,
            seasonality: 2,
            assetBase: 3,
            scalability: 2,
            marketSize: 3,
            margins: 4,
            traction: 2,
            impact: 5,
            earlyStage: 4,
            marketGap: 4,
            currentCash: 45000,
            monthlyBurn: 8000,
            targetRaise: 150000
        };

        const config = [
            { id: 'revPredictability', label: 'Revenue Predictability', section: 'ops' },
            { id: 'seasonality', label: 'Seasonality (Stability)', section: 'ops' },
            { id: 'assetBase', label: 'Asset Tangibility', section: 'ops' },
            { id: 'scalability', label: 'Scalability', section: 'growth' },
            { id: 'marketSize', label: 'Market Size', section: 'growth' },
            { id: 'traction', label: 'Tech Leverage', section: 'growth' },
            { id: 'impact', label: 'ESG / Social Impact', section: 'impact' },
            { id: 'marketGap', label: 'Ecosystem Gap', section: 'impact' }
        ];

        let radarChart, areaChart;

        // --- CORE LOGIC ---
        function calculateScores() {
            return {
                debt: ((state.revPredictability + state.repaymentCapacity + state.seasonality + state.assetBase) / 4).toFixed(1),
                equity: ((state.scalability + state.marketSize + state.margins + state.traction) / 4).toFixed(1),
                blended: ((state.impact + (6 - state.seasonality) + state.marketGap) / 3).toFixed(1),
                grant: ((state.impact + state.earlyStage + (6 - state.traction)) / 3).toFixed(1)
            };
        }

        function getRecommendation(scores) {
            const max = Math.max(scores.debt, scores.equity, scores.blended, scores.grant);
            if (scores.debt == max) return {
                type: 'DEBT / RBF',
                color: 'blue',
                suggestions: ["Lock in multi-year contracts", "Improve DSCR Ratio", "Explore Revenue-Based Finance"],
                checklist: ["Current P&L statements", "3-year cash projections", "Asset register"]
            };
            if (scores.equity == max) return {
                type: 'VENTURE EQUITY',
                color: 'purple',
                suggestions: ["Show 10x growth potential", "Protect IP assets", "Identify exit acquirers"],
                checklist: ["Pitch deck", "Cap table model", "Data room setup"]
            };
            if (scores.blended == max) return {
                type: 'BLENDED FINANCE',
                color: 'emerald',
                suggestions: ["Quantify ESG metrics", "Partner with DFIs", "Layer grant capital"],
                checklist: ["Impact framework", "Partner MOUs", "Compliance audit"]
            };
            return {
                type: 'GRANT / BRIDGE',
                color: 'orange',
                suggestions: ["Align with gov goals", "Apply for tech grants", "Focus on impact"],
                checklist: ["Grant schedule", "Sustainability report", "Project accounting"]
            };
        }

        // --- UI UPDATES ---
        function initInputs() {
            config.forEach(item => {
                const container = document.getElementById(`inputs-${item.section}`);
                const div = document.createElement('div');
                div.innerHTML = `
                    <div class="flex justify-between text-[10px] font-bold text-slate-500 uppercase">
                        <span>${item.label}</span>
                        <span id="val-${item.id}" class="text-indigo-600">${state[item.id]}</span>
                    </div>
                    <input type="range" min="1" max="5" step="0.5" value="${state[item.id]}" 
                        class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer mt-1"
                        oninput="updateState('${item.id}', this.value)">
                `;
                container.appendChild(div);
            });
        }

        function updateState(id, val) {
            state[id] = parseFloat(val);
            document.getElementById(`val-${id}`).innerText = val;
            updateDashboard();
        }

        function updateDashboard() {
            const scores = calculateScores();
            const rec = getRecommendation(scores);

            // Update Cards
            const cards = document.getElementById('score-cards');
            cards.innerHTML = `
                <div class="bg-white p-5 rounded-xl border border-slate-200">
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Debt Fit</p>
                    <span class="text-2xl font-black">${scores.debt}</span>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-200">
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Equity Fit</p>
                    <span class="text-2xl font-black">${scores.equity}</span>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-200">
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Blended Fit</p>
                    <span class="text-2xl font-black">${scores.blended}</span>
                </div>
                <div class="bg-${rec.color}-50 p-5 rounded-xl border border-${rec.color}-200">
                    <p class="text-[10px] font-bold text-${rec.color}-600 uppercase">Top Path</p>
                    <span class="text-xl font-black text-${rec.color}-700">${rec.type}</span>
                </div>
            `;

            // Update Suggestions
            document.getElementById('suggestion-list').innerHTML = rec.suggestions.map(s => `
                <li class="text-xs text-slate-600 flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-slate-300 rounded-full"></span> ${s}
                </li>
            `).join('');

            // Update Checklist
            document.getElementById('checklist-items').innerHTML = rec.checklist.map(c => `
                <div class="flex items-center gap-2 text-[11px]">
                    <div class="w-3 h-3 border border-white/30 rounded flex items-center justify-center">✓</div>
                    <span>${c}</span>
                </div>
            `).join('');

            updateCharts(scores);
        }

        function updateCharts(scores) {
            // Radar Chart
            const radarCtx = document.getElementById('radarChart').getContext('2d');
            if (radarChart) radarChart.destroy();
            radarChart = new Chart(radarCtx, {
                type: 'radar',
                data: {
                    labels: ['Debt', 'Equity', 'Blended', 'Grant'],
                    datasets: [{
                        data: [scores.debt, scores.equity, scores.blended, scores.grant],
                        backgroundColor: 'rgba(79, 70, 229, 0.2)',
                        borderColor: '#4f46e5',
                        pointBackgroundColor: '#4f46e5'
                    }]
                },
                options: { 
                    scales: { r: { min: 0, max: 5, ticks: { display: false } } },
                    plugins: { legend: { display: false } },
                    maintainAspectRatio: false
                }
            });

            // Area Chart
            const areaCtx = document.getElementById('areaChart').getContext('2d');
            const months = Array.from({length: 12}, (_, i) => `M${i}`);
            const funded = months.map((_, i) => Math.max(0, state.currentCash - (state.monthlyBurn * i) + (i >= 3 ? state.targetRaise : 0)));
            const baseline = months.map((_, i) => Math.max(0, state.currentCash - (state.monthlyBurn * i)));

            if (areaChart) areaChart.destroy();
            areaChart = new Chart(areaCtx, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: [
                        { label: 'With Funding', data: funded, fill: true, borderColor: '#4f46e5', backgroundColor: 'rgba(79, 70, 229, 0.1)', tension: 0.4 },
                        { label: 'No Funding', data: baseline, borderColor: '#cbd5e1', borderDash: [5, 5], fill: false, tension: 0.4 }
                    ]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10 } } } },
                    scales: { y: { ticks: { font: { size: 9 } } }, x: { ticks: { font: { size: 9 } } } }
                }
            });
        }

        window.onload = () => {
            initInputs();
            updateDashboard();
        };
    </script>
</body>
</html>
