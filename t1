<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Capital-Fit Scorecard 2.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        
        input[type="range"] {
            -webkit-appearance: none;
            width: 100%;
            height: 4px;
            background: #f1f5f9;
            border-radius: 2px;
            outline: none;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 14px;
            height: 14px;
            background: #4f46e5;
            cursor: pointer;
            border-radius: 50%;
        }
        .custom-card {
            background: #ffffff;
            border-radius: 20px;
            border: 1px solid #f1f5f9;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
        @media print { .no-print { display: none; } }
    </style>
</head>
<body class="bg-[#fafbfc] text-[#1e293b]">

    <div class="flex flex-col min-h-screen">
        <!-- Header -->
        <header class="bg-white border-b border-slate-100 px-8 py-5 flex justify-between items-center sticky top-0 z-50">
            <div>
                <h1 class="text-xl font-extrabold tracking-tight text-slate-800">CAPITAL-FIT SCORECARD 2.0</h1>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Tourism SME Financing Framework</p>
            </div>
            <div class="flex gap-3 no-print">
                <button onclick="window.print()" class="px-4 py-2 text-xs font-bold bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition-all uppercase tracking-wider">Download PDF</button>
            </div>
        </header>

        <div class="flex flex-1 overflow-hidden">
            <!-- Left Sidebar: 9 Dimensions -->
            <aside class="w-[380px] bg-white border-r border-slate-100 overflow-y-auto p-8 no-print">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest">Business Dimensions</h2>
                    <button onclick="resetValues()" class="text-[10px] font-bold text-indigo-600 hover:underline">Reset</button>
                </div>
                
                <div id="dimension-controls" class="space-y-8">
                    <!-- JS populated sliders -->
                </div>

                <div class="mt-10 pt-8 border-t border-slate-100">
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Liquidity Baseline</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="text-[10px] font-bold text-slate-500 uppercase">Cash on Hand (USD)</label>
                            <input type="number" id="cash" value="45000" onchange="updateData()" class="w-full mt-1 p-3 bg-slate-50 border border-slate-100 rounded-xl text-sm font-bold outline-none focus:border-indigo-500">
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-slate-500 uppercase">Monthly Burn (USD)</label>
                            <input type="number" id="burn" value="6500" onchange="updateData()" class="w-full mt-1 p-3 bg-slate-50 border border-slate-100 rounded-xl text-sm font-bold outline-none focus:border-indigo-500">
                        </div>
                        <div class="p-4 bg-indigo-50 rounded-xl">
                            <p class="text-[10px] font-bold text-indigo-400 uppercase">Current Runway</p>
                            <p class="text-xl font-black text-indigo-700" id="runway-display">0 Months</p>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Main Workspace -->
            <main class="flex-1 overflow-y-auto p-10 space-y-8">
                
                <!-- 4 Top Cards (Image 2 Style) -->
                <div class="grid grid-cols-4 gap-6" id="top-cards">
                    <!-- JS Populated -->
                </div>

                <div class="grid grid-cols-12 gap-8">
                    <!-- Radar Overlay (Image 1 Style) -->
                    <div class="col-span-12 lg:col-span-7 bg-white p-8 rounded-[32px] border border-slate-100 shadow-sm">
                        <h3 class="text-sm font-black text-[#1e293b] uppercase tracking-wider mb-8">FITNESS RADAR OVERLAY</h3>
                        <div class="h-[400px] flex items-center justify-center">
                            <canvas id="fitnessRadar"></canvas>
                        </div>
                    </div>

                    <!-- Recommendations (Image 3 Style) -->
                    <div class="col-span-12 lg:col-span-5 space-y-6">
                        <!-- Primary -->
                        <div id="primary-card" class="p-8 rounded-[32px] border-2 transition-all">
                            <!-- JS Populated -->
                        </div>

                        <!-- Secondary -->
                        <div id="secondary-card" class="bg-white p-8 rounded-[32px] border border-slate-100 shadow-sm">
                            <!-- JS Populated -->
                        </div>

                        <!-- Checklist -->
                        <div class="bg-[#1e293b] p-8 rounded-[32px] text-white shadow-xl">
                            <h3 class="text-xs font-black uppercase tracking-widest mb-6 text-slate-400">READINESS CHECKLIST</h3>
                            <ul id="checklist" class="space-y-4">
                                <!-- JS Populated -->
                            </ul>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        const dimensions = [
            { id: 'd1', label: 'D1: Revenue Predictability', core: 'DEBT', question: 'Stability of monthly cash flows?' },
            { id: 'd2', label: 'D2: Unit Economics', core: 'EQUITY/RBF', question: 'Gross margin level (>40%?)' },
            { id: 'd3', label: 'D3: Scalability', core: 'EQUITY', question: 'Outsized growth potential?' },
            { id: 'd4', label: 'D4: Seasonality Risk', core: 'DEBT', question: 'Ability to generate off-season rev?' },
            { id: 'd5', label: 'D5: Asset Intensity', core: 'DEBT', question: 'Collateralizable assets available?' },
            { id: 'd6', label: 'D6: Repayment Capacity', core: 'DEBT', question: 'Operating cash flow coverage?' },
            { id: 'd7', label: 'D7: Market Traction', core: 'SCALE', question: 'Proven willingness to pay?' },
            { id: 'd8', label: 'D8: Impact Value', core: 'BLENDED', question: 'Measurable social/env impact?' },
            { id: 'd9', label: 'D9: Founder Strategy', core: 'FIT', question: 'Willingness to dilute equity?' }
        ];

        let state = {
            d1: 4, d2: 3, d3: 2, d4: 4, d5: 5, d6: 4, d7: 3, d8: 2, d9: 3
        };

        let radarChart;

        function init() {
            const container = document.getElementById('dimension-controls');
            dimensions.forEach(d => {
                const div = document.createElement('div');
                div.innerHTML = `
                    <div class="flex justify-between items-baseline mb-2">
                        <label class="text-[11px] font-extrabold text-slate-700 uppercase tracking-tight">${d.label}</label>
                        <span class="text-xs font-black text-indigo-600" id="val-${d.id}">${state[d.id]}</span>
                    </div>
                    <p class="text-[10px] text-slate-400 mb-2 italic">${d.question}</p>
                    <input type="range" min="1" max="5" step="0.5" value="${state[d.id]}" 
                           oninput="updateVal('${d.id}', this.value)">
                `;
                container.appendChild(div);
            });
            updateData();
        }

        function updateVal(id, val) {
            state[id] = parseFloat(val);
            document.getElementById(`val-${id}`).innerText = val;
            updateData();
        }

        function resetValues() {
            Object.keys(state).forEach(key => state[key] = 3);
            location.reload();
        }

        function updateData() {
            // Formula Logic from Tool 1
            const debtScore = (state.d1 + state.d6 + state.d4 + state.d5) / 4;
            const equityScore = (state.d3 + state.d2 + state.d7) / 3; // Simplified for fit
            const blendedScore = (state.d8 + (6 - state.d4) + (6 - state.d7)) / 3; // Risk + Impact
            const nonDilutiveScore = (state.d8 + (6 - state.d7)) / 2;

            const scores = [
                { id: 'Debt', label: 'DEBT FIT', val: debtScore.toFixed(1), color: '#4f46e5' },
                { id: 'Equity', label: 'EQUITY FIT', val: equityScore.toFixed(1), color: '#7c3aed' },
                { id: 'Blended', label: 'BLENDED FIT', val: blendedScore.toFixed(1), color: '#0891b2' },
                { id: 'Non-Dilutive', label: 'NON-DILUTIVE', val: nonDilutiveScore.toFixed(1), color: '#f97316' }
            ];

            // Update Top Cards
            document.getElementById('top-cards').innerHTML = scores.map(s => `
                <div class="bg-white p-6 rounded-2xl border ${s.val >= 4 ? 'border-indigo-500 ring-1 ring-indigo-500' : 'border-slate-100'} shadow-sm">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">${s.label}</p>
                    <div class="flex items-baseline gap-1">
                        <span class="text-3xl font-black text-slate-800">${s.val}</span>
                        <span class="text-xs font-bold text-slate-300">/ 5.0</span>
                    </div>
                </div>
            `).join('');

            // Liquidity
            const cash = parseFloat(document.getElementById('cash').value);
            const burn = parseFloat(document.getElementById('burn').value);
            const runway = burn > 0 ? (cash / burn).toFixed(1) : '∞';
            document.getElementById('runway-display').innerText = `${runway} Months`;

            // Recommendation Logic
            const sorted = [...scores].sort((a, b) => b.val - a.val);
            renderRecommendations(sorted[0], sorted[1]);

            // Radar
            renderRadar(scores);
        }

        function renderRecommendations(primary, secondary) {
            const content = {
                'Debt': { 
                    title: 'Debt / RBF', 
                    theme: 'border-indigo-100 bg-indigo-50 text-indigo-700',
                    points: ['Stable Cash Flows', 'Asset Backing', 'Repayment Capacity'],
                    checklist: ['3-Year Projections', 'Asset Register', 'Operating Cash Analysis']
                },
                'Equity': { 
                    title: 'Venture Equity', 
                    theme: 'border-purple-100 bg-purple-50 text-purple-700',
                    points: ['Scalability Deck', 'TAM Analysis', 'Exit Strategy'],
                    checklist: ['Pitch Deck', 'Cap Table', 'Data Room']
                },
                'Blended': { 
                    title: 'Blended Finance', 
                    theme: 'border-cyan-100 bg-cyan-50 text-cyan-700',
                    points: ['Impact Framework', 'Risk Mitigation', 'Strategic Fit'],
                    checklist: ['Impact Report', 'MOU with Partners', 'Additionality Proof']
                },
                'Non-Dilutive': { 
                    title: 'Grants / Non-Dilutive', 
                    theme: 'border-orange-100 bg-orange-50 text-orange-700',
                    points: ['Technical Assistance', 'Social Mission', 'Pilot Funding'],
                    checklist: ['Grant Proposal', 'Compliance Plan', 'Stakeholder Letters']
                }
            };

            const p = content[primary.id];
            const s = content[secondary.id];

            document.getElementById('primary-card').className = `p-8 rounded-[32px] border-2 shadow-sm ${p.theme}`;
            document.getElementById('primary-card').innerHTML = `
                <p class="text-[10px] font-black uppercase tracking-widest mb-4 opacity-70">PRIMARY RECOMMENDATION</p>
                <h2 class="text-4xl font-black mb-6">${p.title}</h2>
                <ul class="space-y-3">
                    ${p.points.map(pt => `<li class="flex items-center gap-3 text-sm font-bold">
                        <span class="w-1.5 h-1.5 rounded-full bg-current opacity-40"></span> ${pt}
                    </li>`).join('')}
                </ul>
            `;

            document.getElementById('secondary-card').innerHTML = `
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">SECONDARY PATH</p>
                <h3 class="text-xl font-black text-slate-800">${s.title}</h3>
                <p class="text-xs text-slate-500 font-medium mt-2">Consider as a bridge or layer to increase capital-fit.</p>
            `;

            document.getElementById('checklist').innerHTML = p.checklist.map(item => `
                <li class="flex items-center gap-4 text-xs font-bold tracking-tight">
                    <div class="w-5 h-5 rounded-full bg-emerald-500 flex items-center justify-center text-[10px] text-white">✓</div>
                    ${item}
                </li>
            `).join('');
        }

        function renderRadar(scores) {
            const ctx = document.getElementById('fitnessRadar').getContext('2d');
            const data = {
                labels: ['Debt', 'Equity', 'Blended', 'Non-Dilutive'],
                datasets: [{
                    data: scores.map(s => s.val),
                    backgroundColor: 'rgba(79, 70, 229, 0.12)',
                    borderColor: '#4f46e5',
                    borderWidth: 3,
                    pointBackgroundColor: '#4f46e5',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            };

            if (radarChart) radarChart.destroy();
            radarChart = new Chart(ctx, {
                type: 'radar',
                data: data,
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            min: 0,
                            max: 5,
                            beginAtZero: true,
                            ticks: { display: false, stepSize: 1 },
                            grid: { color: '#f1f5f9' },
                            angleLines: { color: '#f1f5f9' },
                            pointLabels: {
                                font: { size: 12, weight: 'bold', family: 'Inter' },
                                color: '#64748b'
                            }
                        }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        }

        window.onload = init;
    </script>
</body>
</html>
