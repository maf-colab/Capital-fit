<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Capital-Fit Logic Engine</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; color: #0f172a; }
        .slider-thumb::-webkit-slider-thumb {
            -webkit-appearance: none; height: 18px; width: 18px; border-radius: 50%;
            background: #4f46e5; cursor: pointer; border: 3px solid white; box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        input[type=range] { -webkit-appearance: none; background: #e2e8f0; height: 6px; border-radius: 3px; }
        .blister-card { border-left: 6px solid #e2e8f0; transition: all 0.3s; }
        .blister-card:hover { border-left-color: #4f46e5; transform: translateX(4px); }
        .blocker-label { font-size: 9px; font-weight: 900; letter-spacing: 0.05em; padding: 2px 6px; border-radius: 4px; }
    </style>
</head>
<body class="bg-slate-50">

    <div class="flex flex-col min-h-screen">
        <header class="bg-white border-b border-slate-200 px-10 py-6 flex justify-between items-center sticky top-0 z-50">
            <div>
                <h1 class="text-2xl font-black italic tracking-tighter uppercase">Capital-Fit <span class="text-indigo-600">Engine</span></h1>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Logic: Weighted Matrix v3.1 (Strict Mode)</p>
            </div>
            <div class="flex items-center gap-6">
                <div class="text-right">
                    <p class="text-[9px] font-black text-slate-400 uppercase">System Status</p>
                    <p id="system-status" class="text-xs font-bold text-green-500 uppercase tracking-tighter">● All Decision Rules Active</p>
                </div>
                <button onclick="window.print()" class="px-8 py-3 bg-slate-900 text-white text-xs font-black rounded-full hover:bg-black transition-all uppercase tracking-widest shadow-lg">Generate Report</button>
            </div>
        </header>

        <div class="flex flex-1 overflow-hidden">
            <!-- INPUT SIDEBAR -->
            <aside class="w-[480px] bg-white border-r border-slate-200 overflow-y-auto p-8 no-print">
                <div class="mb-10">
                    <h2 class="text-xs font-black text-slate-800 uppercase tracking-widest mb-6 border-b pb-2">Venture Physics Inputs</h2>
                    <div id="dimension-list" class="space-y-8">
                        <!-- Populated by JS -->
                    </div>
                </div>

                <div class="mt-12 pt-10 border-t border-slate-200">
                    <h2 class="text-xs font-black text-slate-800 uppercase tracking-widest mb-6 italic">Liquidity Monitor</h2>
                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase">Available Cash ($)</label>
                            <input type="number" id="cash-input" value="120000" oninput="updateSystem()" class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl font-black text-lg outline-none focus:border-indigo-500">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase">Monthly Burn ($)</label>
                            <input type="number" id="burn-input" value="15000" oninput="updateSystem()" class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl font-black text-lg outline-none focus:border-indigo-500">
                        </div>
                    </div>
                </div>
            </aside>

            <!-- RESULTS MAIN -->
            <main class="flex-1 overflow-y-auto p-10 space-y-10">
                
                <!-- SCORE OVERVIEW (STEP 3) -->
                <div class="grid grid-cols-4 gap-6" id="score-matrix">
                    <!-- Cards -->
                </div>

                <div class="grid grid-cols-12 gap-10">
                    <div class="col-span-7 space-y-10">
                        <!-- SPIDER GRAPH (CAPITAL FIT OVERLAY) -->
                        <div class="bg-white p-10 rounded-[40px] border border-slate-200 shadow-sm">
                            <div class="flex justify-between items-end mb-8">
                                <div>
                                    <h3 class="text-sm font-black text-slate-900 uppercase italic tracking-widest">Capital Fitness Overlay</h3>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase mt-1">Weighted Distribution Model</p>
                                </div>
                            </div>
                            <div class="h-[400px]">
                                <canvas id="radarChart"></canvas>
                            </div>
                        </div>

                        <!-- LIQUIDITY GRAPH -->
                        <div class="bg-white p-10 rounded-[40px] border border-slate-200 shadow-sm">
                            <div class="flex justify-between items-center mb-6">
                                <h3 class="text-sm font-black text-slate-900 uppercase italic tracking-widest">Cash Runway Velocity</h3>
                                <div id="runway-badge" class="px-5 py-2 bg-slate-900 text-white text-xs font-black rounded-full uppercase italic">8.0 Months</div>
                            </div>
                            <div class="h-[200px]">
                                <canvas id="runwayChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- RECOMMENDATIONS (STEP 4) -->
                    <div class="col-span-5 space-y-6">
                        <div id="primary-rec" class="p-10 rounded-[40px] border-4 transition-all"></div>
                        <div id="secondary-rec" class="bg-white p-8 rounded-[40px] border border-slate-200"></div>
                        <div id="rejected-rec" class="bg-slate-100/50 p-6 rounded-[40px] border border-dashed border-slate-300 opacity-60"></div>
                        
                        <!-- BLOCKER LOG -->
                        <div class="bg-red-50 p-8 rounded-[40px] border border-red-100 hidden" id="blocker-box">
                            <h4 class="text-[10px] font-black text-red-600 uppercase tracking-widest mb-4 italic">Hard Decision Violations</h4>
                            <ul id="blocker-list" class="space-y-2"></ul>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        const dimensions = [
            { id: 'd1', label: 'Revenue Predictability', q: 'Predictable monthly revenue?', indicators: 'Advance bookings, contracts, repeat customers.', weights: { debt: 3, equity: 1, blended: 2, grant: -1 }, blocker: { type: 'debt', threshold: 3 } },
            { id: 'd2', label: 'Unit Economics', q: 'Gross margin level & stability?', indicators: 'Pricing power, cost flexibility, scalability.', weights: { debt: 2, equity: 3, blended: 2, grant: 1 } },
            { id: 'd3', label: 'Scalability', q: 'Expand beyond location?', indicators: 'Replicable model, market size, non-linear growth.', weights: { debt: 1, equity: 3, blended: 2, grant: -1 }, blocker: { type: 'equity', threshold: 3 } },
            { id: 'd4', label: 'Seasonality / Risk', q: 'Revenue concentration / exposure?', indicators: 'Off-season revenue, external shocks, flexibility.', weights: { debt: -2, equity: 2, blended: 3, grant: 2 } },
            { id: 'd5', label: 'Asset Intensity', q: 'CAPEX needs & collateral?', indicators: 'Asset utilization, return speed, collateral.', weights: { debt: 2, equity: -1, blended: 2, grant: 1 } },
            { id: 'd6', label: 'Repayment Capacity', q: 'Positive cash flow coverage?', indicators: 'Covers fixed payments, cash buffer, inflows.', weights: { debt: 3, equity: -1, blended: 2, grant: -1 }, blocker: { type: 'debt', threshold: 3 } },
            { id: 'd7', label: 'Traction / Validation', q: 'Paying customers & growth trend?', indicators: 'Validated channels, partnerships, retention.', weights: { debt: 2, equity: 3, blended: 2, grant: -1 } },
            { id: 'd8', label: 'Impact / Strategic', q: 'Job creation & local linkages?', indicators: 'Environmental impact, donor alignment.', weights: { debt: 1, equity: 1, blended: 3, grant: 3 }, blocker: { type: 'grant', threshold: 3 } },
            { id: 'd9', label: 'Founder Strategy', q: 'Willingness to dilute?', indicators: 'Control preference, risk tolerance, ambition.', weights: { debt: 1, equity: 2, blended: 2, grant: 1 } }
        ];

        let state = { d1: 4, d2: 4, d3: 2.5, d4: 3, d5: 3.5, d6: 4, d7: 3, d8: 4, d9: 3 };
        let radarChart, runwayChart;

        function init() {
            const list = document.getElementById('dimension-list');
            dimensions.forEach(d => {
                const card = document.createElement('div');
                card.className = 'blister-card p-5 bg-slate-50 rounded-2xl border border-slate-100';
                card.innerHTML = `
                    <div class="flex justify-between items-start mb-1">
                        <label class="text-[11px] font-black uppercase tracking-tight text-slate-800">${d.label}</label>
                        <span class="text-sm font-black text-indigo-600" id="val-${d.id}">${state[d.id]}</span>
                    </div>
                    <p class="text-[10px] font-bold text-slate-500 mb-4 leading-tight">${d.q}</p>
                    <input type="range" min="1" max="5" step="0.5" value="${state[d.id]}" oninput="updateVal('${d.id}', this.value)" class="w-full slider-thumb">
                    <div class="mt-3 flex justify-between text-[8px] font-black text-slate-400 uppercase tracking-tighter">
                        <span>Lacking</span>
                        <span>Baseline (3.0)</span>
                        <span>Excellent</span>
                    </div>
                `;
                list.appendChild(card);
            });
            updateSystem();
        }

        function updateVal(id, val) {
            state[id] = parseFloat(val);
            document.getElementById(`val-${id}`).innerText = val;
            updateSystem();
        }

        function calculateScore(type) {
            let totalWeight = 0;
            let weightedSum = 0;
            
            dimensions.forEach(d => {
                const w = d.weights[type];
                if (w !== 0) {
                    const weight = Math.abs(w);
                    const score = w < 0 ? (6 - state[d.id]) : state[d.id];
                    weightedSum += (score * weight);
                    totalWeight += weight;
                }
            });
            return (weightedSum / totalWeight).toFixed(1);
        }

        function updateSystem() {
            const scores = {
                debt: calculateScore('debt'),
                equity: calculateScore('equity'),
                blended: calculateScore('blended'),
                grant: calculateScore('grant')
            };

            // Hard Blockers Check (Step 4)
            const blockers = [];
            if (state.d6 < 3) blockers.push("DEBT: Repayment capacity too low (<3)");
            if (state.d1 < 3) blockers.push("DEBT: Revenue predictability too low (<3)");
            if (state.d3 < 3) blockers.push("EQUITY: Scalability too low (<3)");
            if (state.d8 < 3) blockers.push("GRANT: Impact score too low (<3)");

            // Hybrid Trigger
            const hybridTriggered = (scores.debt < 3 && scores.equity < 3 && state.d8 >= 4);

            renderScores(scores, blockers);
            renderRecommendations(scores, blockers, hybridTriggered);
            renderVisuals(scores);
        }

        function renderScores(scores, blockers) {
            const container = document.getElementById('score-matrix');
            const map = [
                { id: 'debt', label: 'Debt Fit', val: scores.debt, icon: '🏦', color: 'indigo' },
                { id: 'equity', label: 'Equity Fit', val: scores.equity, icon: '🚀', color: 'purple' },
                { id: 'blended', label: 'Hybrid Fit', val: scores.blended, icon: '⚖️', color: 'cyan' },
                { id: 'grant', label: 'Grant Fit', val: scores.grant, icon: '🌱', color: 'amber' }
            ];

            container.innerHTML = map.map(s => {
                const isBlocked = blockers.some(b => b.startsWith(s.id.toUpperCase()));
                return `
                    <div class="bg-white p-8 rounded-[30px] border-2 ${isBlocked ? 'border-red-200 bg-red-50/20' : 'border-slate-100'} relative overflow-hidden">
                        ${isBlocked ? '<span class="absolute top-2 right-2 blocker-label bg-red-600 text-white">HARD BLOCK</span>' : ''}
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">${s.label}</p>
                        <div class="flex items-center justify-between">
                            <span class="text-4xl font-black ${isBlocked ? 'text-red-400' : 'text-slate-900'}">${s.val}</span>
                            <span class="text-2xl opacity-40">${s.icon}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderRecommendations(scores, blockers, hybridTriggered) {
            const sorted = Object.entries(scores)
                .filter(([id]) => !blockers.some(b => b.startsWith(id.toUpperCase())))
                .sort((a, b) => b[1] - a[1]);

            const primaryEl = document.getElementById('primary-rec');
            const secondaryEl = document.getElementById('secondary-rec');
            const rejectedEl = document.getElementById('rejected-rec');
            const blockerBox = document.getElementById('blocker-box');

            if (sorted.length > 0) {
                const [pId, pVal] = sorted[0];
                const styles = {
                    debt: 'bg-indigo-600 text-white border-indigo-700 shadow-indigo-200',
                    equity: 'bg-purple-600 text-white border-purple-700 shadow-purple-200',
                    blended: 'bg-cyan-600 text-white border-cyan-700 shadow-cyan-200',
                    grant: 'bg-amber-500 text-white border-amber-600 shadow-amber-200'
                };
                
                primaryEl.className = `p-10 rounded-[40px] border-4 transition-all shadow-2xl ${styles[pId]}`;
                primaryEl.innerHTML = `
                    <p class="text-[10px] font-black uppercase tracking-[0.3em] mb-4 opacity-70">🥇 Primary Strategy</p>
                    <h2 class="text-5xl font-black mb-6 uppercase italic">${pId} / RBF</h2>
                    <p class="text-sm font-bold opacity-90 leading-relaxed">System logic confirms this instrument aligns with your venture's current cash flow velocity and asset base.</p>
                `;

                if (sorted[1]) {
                    secondaryEl.innerHTML = `
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">🥈 Secondary Path</p>
                        <h3 class="text-2xl font-black text-slate-900 uppercase italic">${sorted[1][0]}</h3>
                        <p class="text-[10px] text-slate-500 font-bold uppercase mt-1">Viable secondary layer or bridge</p>
                    `;
                }
            }

            const rejected = Object.keys(scores).filter(id => !sorted.find(s => s[0] === id));
            rejectedEl.innerHTML = `
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 italic">❌ Non-Compatible Capital</p>
                <div class="flex gap-2">
                    ${rejected.map(r => `<span class="px-3 py-1 bg-white rounded-full text-[9px] font-black text-red-500 uppercase border border-red-100">${r}</span>`).join('')}
                </div>
            `;

            if (blockers.length > 0) {
                blockerBox.classList.remove('hidden');
                document.getElementById('blocker-list').innerHTML = blockers.map(b => `
                    <li class="flex items-start gap-2 text-[10px] font-black text-red-700 uppercase tracking-tighter">
                        <span>⚠️</span> ${b}
                    </li>
                `).join('');
            } else {
                blockerBox.classList.add('hidden');
            }
        }

        function renderVisuals(scores) {
            // Radar
            const ctx = document.getElementById('radarChart').getContext('2d');
            if (radarChart) radarChart.destroy();
            radarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['DEBT', 'EQUITY', 'BLENDED', 'GRANT'],
                    datasets: [{
                        data: [scores.debt, scores.equity, scores.blended, scores.grant],
                        backgroundColor: 'rgba(79, 70, 229, 0.1)',
                        borderColor: '#4f46e5',
                        borderWidth: 5,
                        pointRadius: 6,
                        pointBackgroundColor: '#fff'
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: { r: { min: 0, max: 5, ticks: { display: false }, grid: { color: '#e2e8f0' }, pointLabels: { font: { size: 12, weight: '900' } } } },
                    plugins: { legend: { display: false } }
                }
            });

            // Runway
            const cash = parseFloat(document.getElementById('cash-input').value);
            const burn = parseFloat(document.getElementById('burn-input').value);
            const runway = burn > 0 ? (cash / burn).toFixed(1) : 0;
            document.getElementById('runway-badge').innerText = `${runway} Months Runway`;

            const rCtx = document.getElementById('runwayChart').getContext('2d');
            if (runwayChart) runwayChart.destroy();
            const labels = Array.from({length: 12}, (_, i) => `M${i}`);
            const data = labels.map((_, i) => Math.max(0, cash - (burn * i)));
            runwayChart = new Chart(rCtx, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{ data, borderColor: '#0f172a', borderWidth: 4, fill: true, backgroundColor: 'rgba(15, 23, 42, 0.05)', tension: 0.4, pointRadius: 0 }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { 
                        y: { ticks: { display: false }, grid: { display: false } },
                        x: { grid: { display: false }, ticks: { font: { size: 10, weight: '900' } } }
                    }
                }
            });
        }

        window.onload = init;
    </script>
</body>
</html>
