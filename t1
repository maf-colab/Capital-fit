import React, { useState, useMemo } from 'react';
import { 
  XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, 
  RadarChart, PolarGrid, PolarAngleAxis, PolarRadiusAxis, Radar,
  AreaChart, Area
} from 'recharts';
import { 
  TrendingUp, Shield, ChevronRight, AlertTriangle, CheckCircle, Info,
  Settings, Download, RefreshCw, User, Lightbulb, Target, ArrowRight
} from 'lucide-react';

const App = () => {
  // --- STATE ---
  const [inputs, setInputs] = useState({
    revPredictability: 4,
    repaymentCapacity: 3,
    seasonality: 2, // 1 = High Seasonality (Bad for debt), 5 = Stable (Good for debt)
    assetBase: 3,
    scalability: 2,
    marketSize: 3,
    margins: 4,
    traction: 2,
    impact: 5,
    earlyStage: 4,
    marketGap: 4,
    currentCash: 45000,
    monthlyBurn: 8000,
    targetRaise: 150000
  });

  // --- CALCULATIONS ---
  const scores = useMemo(() => {
    const debt = (inputs.revPredictability + inputs.repaymentCapacity + inputs.seasonality + inputs.assetBase) / 4;
    const equity = (inputs.scalability + inputs.marketSize + inputs.margins + inputs.traction) / 4;
    const blended = (inputs.impact + (6 - inputs.seasonality) + inputs.marketGap) / 3; 
    const nonDilutive = (inputs.impact + inputs.earlyStage + (6 - inputs.traction)) / 3; 

    return { 
      debt: parseFloat(debt.toFixed(1)), 
      equity: parseFloat(equity.toFixed(1)), 
      blended: parseFloat(blended.toFixed(1)), 
      nonDilutive: parseFloat(nonDilutive.toFixed(1)) 
    };
  }, [inputs]);

  const runwayData = useMemo(() => {
    let data = [];
    let current = inputs.currentCash;
    const raiseAmount = inputs.targetRaise;
    for (let i = 0; i <= 24; i++) {
      let balance = current - (inputs.monthlyBurn * i);
      let withRaise = balance + (i >= 3 ? raiseAmount : 0);
      data.push({ month: `M${i}`, baseline: Math.max(0, balance), funded: Math.max(0, withRaise) });
    }
    return data;
  }, [inputs]);

  const radarData = [
    { subject: 'Debt Fit', A: scores.debt, fullMark: 5 },
    { subject: 'Equity Fit', A: scores.equity, fullMark: 5 },
    { subject: 'Blended Fit', A: scores.blended, fullMark: 5 },
    { subject: 'Non-Dilutive', A: scores.nonDilutive, fullMark: 5 },
  ];

  const getRecommendation = () => {
    const maxScore = Math.max(scores.debt, scores.equity, scores.blended, scores.nonDilutive);
    if (scores.debt === maxScore) return { 
      id: 'debt',
      type: 'DEBT / RBF', 
      color: 'text-blue-600', bg: 'bg-blue-50', border: 'border-blue-200',
      reason: 'Strong predictable cash flows and existing asset base make you a prime candidate for credit.',
      suggestions: ["Lock in multi-year contracts", "Improve Debt Service Coverage Ratio (DSCR)", "Explore Revenue-Based Finance"],
      checklist: ["Current P&L statements", "3-year cash flow projections", "Asset register for collateral"]
    };
    if (scores.equity === maxScore) return { 
      id: 'equity',
      type: 'VENTURE EQUITY', 
      color: 'text-purple-600', bg: 'bg-purple-50', border: 'border-purple-200',
      reason: 'Your high scalability and market potential justify the cost of dilution.',
      suggestions: ["Demonstrate 10x growth potential", "Protect IP or unique tech", "Identify target exit acquirers"],
      checklist: ["Pitch deck", "Cap table modeling", "Data room setup"]
    };
    if (scores.blended === maxScore) return { 
      id: 'blended',
      type: 'BLENDED FINANCE', 
      color: 'text-emerald-600', bg: 'bg-emerald-50', border: 'border-emerald-200',
      reason: 'High impact and market complexity suggest a mix of concessional and commercial capital.',
      suggestions: ["Quantify ESG/Social metrics", "Partner with DFIs or NGOs", "Structure a risk-sharing facility"],
      checklist: ["Impact measurement framework", "MOU with strategic partners", "Grant compliance audit"]
    };
    return { 
      id: 'grant',
      type: 'NON-DILUTIVE', 
      color: 'text-orange-600', bg: 'bg-orange-50', border: 'border-orange-200',
      reason: 'Early stage and impact focus make non-dilutive capital your best bridge.',
      suggestions: ["Align with government tourism goals", "Apply for innovation grants", "Focus on technical assistance"],
      checklist: ["Grant application schedule", "Project-based accounting", "Sustainability reporting"]
    };
  };

  const rec = getRecommendation();

  // --- UI COMPONENTS ---
  const Slider = ({ label, value, name, min = 1, max = 5, step = 0.5 }) => (
    <div className="mb-4">
      <div className="flex justify-between items-center mb-1">
        <label className="text-xs font-semibold text-slate-600 uppercase tracking-wider">{label}</label>
        <span className="text-sm font-bold text-indigo-600">{value}</span>
      </div>
      <input
        type="range" min={min} max={max} step={step} value={value}
        onChange={(e) => setInputs({ ...inputs, [name]: parseFloat(e.target.value) })}
        className="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
      />
    </div>
  );

  return (
    <div className="min-h-screen bg-slate-50 font-sans text-slate-900 flex flex-col">
      <header className="bg-white border-b border-slate-200 px-8 py-4 flex justify-between items-center sticky top-0 z-50">
        <div className="flex items-center gap-3">
          <div className="bg-indigo-600 p-2 rounded-lg"><TrendingUp className="text-white w-6 h-6" /></div>
          <div>
            <h1 className="text-xl font-bold tracking-tight">Capital-Fit Navigator</h1>
            <p className="text-xs text-slate-500 font-medium">Decision Support for Tourism Ventures</p>
          </div>
        </div>
        <div className="flex items-center gap-4">
          <button className="flex items-center gap-2 px-4 py-2 text-sm font-semibold border border-slate-200 rounded-md hover:bg-slate-50 transition-colors">
            <Download className="w-4 h-4" /> Export Report
          </button>
          <div className="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center border border-indigo-200">
            <User className="w-4 h-4 text-indigo-600" />
          </div>
        </div>
      </header>

      <main className="flex-1 flex overflow-hidden">
        <aside className="w-80 bg-white border-r border-slate-200 overflow-y-auto p-6 scrollbar-hide">
          <h2 className="text-sm font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-slate-400">
            <Settings className="w-4 h-4" /> Venture Physics
          </h2>

          <div className="space-y-8">
            <section>
              <h3 className="text-xs font-black text-slate-400 mb-4 border-b pb-2 uppercase">Revenue & Ops</h3>
              <Slider label="Revenue Predictability" value={inputs.revPredictability} name="revPredictability" />
              <Slider label="Seasonality (Stability)" value={inputs.seasonality} name="seasonality" />
              <Slider label="Asset Tangibility" value={inputs.assetBase} name="assetBase" />
            </section>
            <section>
              <h3 className="text-xs font-black text-slate-400 mb-4 border-b pb-2 uppercase">Growth & Upside</h3>
              <Slider label="Scalability" value={inputs.scalability} name="scalability" />
              <Slider label="Market Size" value={inputs.marketSize} name="marketSize" />
              <Slider label="Tech Leverage" value={inputs.traction} name="traction" />
            </section>
            <section>
              <h3 className="text-xs font-black text-slate-400 mb-4 border-b pb-2 uppercase">Impact</h3>
              <Slider label="ESG / Social" value={inputs.impact} name="impact" />
              <Slider label="Ecosystem Gap" value={inputs.marketGap} name="marketGap" />
            </section>
          </div>
        </aside>

        <div className="flex-1 overflow-y-auto p-8">
          <div className="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
            <div className="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
              <p className="text-xs font-bold text-slate-400 uppercase mb-1">Debt Fit</p>
              <div className="flex items-end justify-between">
                <span className="text-3xl font-black text-slate-800">{scores.debt}</span>
                <span className={`text-[10px] font-bold px-2 py-0.5 rounded ${scores.debt >= 4 ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500'}`}>
                  {scores.debt >= 4 ? 'OPTIMAL' : 'LOW'}
                </span>
              </div>
            </div>
            <div className="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
              <p className="text-xs font-bold text-slate-400 uppercase mb-1">Equity Fit</p>
              <div className="flex items-end justify-between">
                <span className="text-3xl font-black text-slate-800">{scores.equity}</span>
                <span className={`text-[10px] font-bold px-2 py-0.5 rounded ${scores.equity >= 4 ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500'}`}>
                  {scores.equity >= 4 ? 'VC READY' : 'LOW'}
                </span>
              </div>
            </div>
            <div className="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
              <p className="text-xs font-bold text-slate-400 uppercase mb-1">Blended Fit</p>
              <div className="flex items-end justify-between">
                <span className="text-3xl font-black text-slate-800">{scores.blended}</span>
                <span className={`text-[10px] font-bold px-2 py-0.5 rounded ${scores.blended >= 3.5 ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'}`}>
                  {scores.blended >= 3.5 ? 'STRATEGIC' : 'LOW'}
                </span>
              </div>
            </div>
            <div className={`p-5 rounded-xl border ${rec.border} ${rec.bg} shadow-sm`}>
              <p className={`text-xs font-bold ${rec.color} uppercase mb-1`}>Top Path</p>
              <span className={`text-lg font-black ${rec.color}`}>{rec.type}</span>
            </div>
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
            <div className="lg:col-span-2 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <div className="flex justify-between items-center mb-6">
                <h3 className="text-sm font-bold text-slate-800 flex items-center gap-2">
                  <Shield className="w-4 h-4 text-indigo-500" /> Fitness Overlay
                </h3>
              </div>
              <div className="h-[350px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <RadarChart cx="50%" cy="50%" outerRadius="80%" data={radarData}>
                    <PolarGrid stroke="#e2e8f0" />
                    <PolarAngleAxis dataKey="subject" tick={{ fill: '#64748b', fontSize: 12, fontWeight: 700 }} />
                    <PolarRadiusAxis angle={30} domain={[0, 5]} tick={false} axisLine={false} />
                    <Radar name="Fit" dataKey="A" stroke="#4f46e5" fill="#4f46e5" fillOpacity={0.4} />
                  </RadarChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="space-y-6">
              <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                <h3 className="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                  <Lightbulb className="w-4 h-4 text-orange-500" /> Key Suggestions
                </h3>
                <ul className="space-y-3">
                  {rec.suggestions.map((s, i) => (
                    <li key={i} className="flex items-center gap-3 text-sm text-slate-600 group">
                      <div className="w-6 h-6 rounded bg-slate-50 border border-slate-100 flex items-center justify-center text-[10px] font-bold group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                        {i + 1}
                      </div>
                      {s}
                    </li>
                  ))}
                </ul>
              </div>

              <div className="bg-indigo-900 p-6 rounded-2xl shadow-lg shadow-indigo-200 text-white">
                <h3 className="text-sm font-bold mb-4 flex items-center gap-2">
                  <Target className="w-4 h-4 text-indigo-300" /> Readiness Checklist
                </h3>
                <div className="space-y-3">
                  {rec.checklist.map((item, i) => (
                    <div key={i} className="flex items-center gap-3">
                      <div className="w-4 h-4 rounded border border-white/30 flex items-center justify-center">
                        <CheckCircle className="w-3 h-3 text-indigo-300" />
                      </div>
                      <span className="text-xs font-medium opacity-90">{item}</span>
                    </div>
                  ))}
                </div>
                <button className="mt-6 w-full py-2 bg-white text-indigo-900 text-xs font-black rounded-lg hover:bg-indigo-50 transition-colors uppercase tracking-wider">
                  Generate Memo
                </button>
              </div>
            </div>
          </div>

          <div className="bg-white p-8 rounded-2xl border border-slate-200 shadow-sm">
            <div className="flex justify-between items-center mb-8">
              <div>
                <h3 className="text-lg font-bold text-slate-800">Cash Runway Projection</h3>
                <p className="text-sm text-slate-500">How ${inputs.targetRaise.toLocaleString()} from {rec.type} impacts survival.</p>
              </div>
            </div>
            <div className="h-[250px] w-full">
              <ResponsiveContainer width="100%" height="100%">
                <AreaChart data={runwayData}>
                  <defs>
                    <linearGradient id="colorFunded" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="5%" stopColor="#6366f1" stopOpacity={0.3}/>
                      <stop offset="95%" stopColor="#6366f1" stopOpacity={0}/>
                    </linearGradient>
                  </defs>
                  <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" />
                  <XAxis dataKey="month" axisLine={false} tickLine={false} tick={{fill: '#94a3b8', fontSize: 10}} />
                  <YAxis axisLine={false} tickLine={false} tick={{fill: '#94a3b8', fontSize: 10}} tickFormatter={(v) => `$${v/1000}k`}/>
                  <Tooltip contentStyle={{ borderRadius: '12px', border: 'none', boxShadow: '0 10px 15px -3px rgba(0,0,0,0.1)' }} />
                  <Area type="monotone" dataKey="baseline" stroke="#e2e8f0" fill="#f8fafc" strokeWidth={2} />
                  <Area type="monotone" dataKey="funded" stroke="#6366f1" fillOpacity={1} fill="url(#colorFunded)" strokeWidth={3} />
                </AreaChart>
              </ResponsiveContainer>
            </div>
          </div>
        </div>
      </main>
    </div>
  );
};

export default App;
